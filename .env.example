# ============================================================
# CONFIG CLIENTE — Firebase Auth (público, va al navegador)
# Sácalo de Firebase Console > Configuración del proyecto > General
# ============================================================
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=el99-4a9b7.firebaseapp.com
FIREBASE_PROJECT_ID=el99-4a9b7
FIREBASE_APP_ID=1:672251205852:web:83ed0add63cbbad89d3c19

# ============================================================
# CONFIG SERVIDOR — Firebase Admin (SECRETO, nunca al navegador)
# Firebase Console > Configuración del proyecto > Cuentas de servicio
# > Generar nueva clave privada (descarga un JSON)
# ============================================================
FIREBASE_ADMIN_PROJECT_ID=el99-4a9b7
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@el99-4a9b7.iam.gserviceaccount.com
# Pega el "private_key" del JSON tal cual, entre comillas (con los \n)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# UID del usuario admin (Firebase Console > Authentication > Users)
ADMIN_UID=bpIkZDDYO5WggKHJTuMeUTPvMBf2

# URL del Google Apps Script para exportar a Excel (ahora solo la conoce el servidor)
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec
